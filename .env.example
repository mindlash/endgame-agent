# EndGame Agent Configuration
# Copy to .env and fill in your values

# ── Wallet ──────────────────────────────────────────────
# Your Solana wallet address (public key)
WALLET_ADDRESS=

# Path to encrypted keyfile (created by setup wizard)
KEYFILE_PATH=.agent-data/keyfile.json

# ── Claim Settings ──────────────────────────────────────
CLAIM_ENABLED=true
CLAIM_RETRY_ATTEMPTS=5
CLAIM_RETRY_DELAY_MS=2000

# ── Marketing ───────────────────────────────────────────
MARKETING_ENABLED=true
POSTS_PER_DAY=4
REFERRAL_CODE=

# LLM Provider (for content generation)
# Supports: claude, openai
LLM_PROVIDER=claude
CLAUDE_API_KEY=
# OPENAI_API_KEY=

# ── Twitter/X ───────────────────────────────────────────
TWITTER_ENABLED=false
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# ── Discord ─────────────────────────────────────────────
DISCORD_ENABLED=false
DISCORD_WEBHOOK_URL=

# ── Telegram ────────────────────────────────────────────
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=

# ── Advanced ────────────────────────────────────────────
API_BASE_URL=https://api.endgame.cash
API_TIMEOUT_MS=15000
LOG_LEVEL=info
